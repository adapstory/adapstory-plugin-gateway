  "info": {
    "title": "Plugin Gateway API",
    "description": "First-party internal API for BC-02 Plugin Gateway REST proxying, webhook dispatch, and MCP routing for plugin tools.",
    "version": "2026.04.1",
    "summary": "Internal plugin and MCP gateway API",
    "x-adapstory-api-major": "v1",
    "x-adapstory-api-audience": "internal",
    "x-adapstory-ai-ready": true
  },
  "servers": [
    {
      "url": "http://localhost",
      "description": "Generated server url"
    }
  ],
  "paths": {
    "/internal/plugins/v1/{slug}/mcp": {
      "post": {
        "tags": [
          "mcp-route-controller"
        ],
        "summary": "Proxy MCP JSON-RPC call to plugin backend",
        "description": "Routes a JSON-RPC 2.0 MCP request to the plugin pod identified by slug. Injects X-Tenant-Id, X-Request-Id, X-Correlation-Id headers.",
        "operationId": "proxyMcpVersioned",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "description": "Plugin slug identifier (e.g. 'course-builder')",
            "required": true,
            "schema": {
              "type": "string",
              "default": "",
              "maxLength": 254,
              "example": "sample-school"
            },
            "example": "sample-school"
          },
          {
            "name": "X-Idempotency-Key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "maxLength": 128,
              "example": "idem-2026-04-23-0001"
            },
            "description": "Idempotency key for safe retries",
            "example": "idem-2026-04-23-0001"
          }
        ],
        "responses": {
          "200": {
            "description": "MCP response proxied from plugin backend",
            "headers": {
              "X-Response-Id": {
                "description": "Technical response identifier equal to the inbound X-Request-Id.",
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Invalid plugin slug format",
            "headers": {
              "X-Response-Id": {
                "description": "Technical response identifier equal to the inbound X-Request-Id.",
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "502": {
            "description": "Plugin pod unreachable or returned error",
            "headers": {
              "X-Response-Id": {
                "description": "Technical response identifier equal to the inbound X-Request-Id.",
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        },
        "x-AI-ready": true
      }
    },
    "/api/bc-02/gateway/v1/webhooks/{pluginShortId}": {
      "post": {
        "tags": [
          "webhook-dispatcher"
        ],
        "summary": "Dispatch webhook to plugin pod",
        "description": "Forwards CloudEvents 1.0 payload from core BC to the target plugin pod. Dispatch is async (returns 202 immediately). Retries with exponential backoff.",
        "operationId": "dispatchWebhook",
        "parameters": [
          {
            "name": "pluginShortId",
            "in": "path",
            "description": "Plugin short identifier",
            "required": true,
            "schema": {
              "type": "string",
              "default": "",
              "maxLength": 254,
              "example": "item-1"
            },
            "example": "item-1"
          },
          {
            "name": "headers",
            "in": "header",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/HttpHeaders"
            },
            "description": "Headers parameter"
          },
          {
            "name": "X-Idempotency-Key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "maxLength": 128,
              "example": "idem-2026-04-23-0001"
            },
            "description": "Idempotency key for safe retries",
            "example": "idem-2026-04-23-0001"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "string",
                "format": "byte"
              }
            }
          },
          "required": true,
          "description": "Request payload for Dispatch webhook to plugin pod"
        },
        "responses": {
          "202": {
            "description": "Webhook accepted for async delivery",
            "headers": {
              "X-Response-Id": {
                "description": "Technical response identifier equal to the inbound X-Request-Id.",
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Invalid plugin short ID",
            "headers": {
              "X-Response-Id": {
                "description": "Technical response identifier equal to the inbound X-Request-Id.",
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "403": {
            "description": "Invalid internal secret",
            "headers": {
              "X-Response-Id": {
                "description": "Technical response identifier equal to the inbound X-Request-Id.",
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        },
        "x-AI-ready": true
      }
    },
