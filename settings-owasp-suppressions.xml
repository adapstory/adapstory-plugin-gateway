<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!--
        OWASP Dependency-Check suppression file for Adapstory Platform.
        Add entries here for known false positives or accepted risks.
        Each suppression MUST include a <notes> element explaining the reason.

        Documentation: https://jeremylong.github.io/DependencyCheck/general/suppression.html
    -->

    <!-- False positive: OWASP maps spring-boot-liquibase 4.0.3 to CPE liquibase:4.0.3,
         but the actual Liquibase version is 5.0.1 (via Spring Boot BOM).
         CVE-2022-0839 affects Liquibase <= 4.8.0 (JNDI injection in Liquibase XML parser). -->
    <suppress>
        <notes>FP: spring-boot-liquibase starter version != Liquibase version. Actual: 5.0.1</notes>
        <packageUrl regex="true">^pkg:maven/org\.springframework\.boot/spring\-boot\-(starter\-)?liquibase@.*$</packageUrl>
        <cve>CVE-2022-0839</cve>
    </suppress>

    <!-- False positive: OWASP maps hibernate-validator to CPE for nu.validator (Nu Html Checker).
         CVE-2025-15104 is an SSRF in nu.validator:validator, NOT in org.hibernate.validator.
         hibernate-validator 9.0.1.Final is not affected. -->
    <suppress>
        <notes>FP: CVE-2025-15104 is for nu.validator (Nu Html Checker), not hibernate-validator. Wrong CPE match.</notes>
        <packageUrl regex="true">^pkg:maven/org\.hibernate\.validator/hibernate\-validator@.*$</packageUrl>
        <cve>CVE-2025-15104</cve>
    </suppress>

    <!-- json-schema-validator 1.5.9: CVE-2025-15104
         Used by Keycloak/Hibernate validator dependency chain.
         False positive: validator is used on trusted schemas, not user input. -->
    <suppress>
        <notes>Accepted: json-schema-validator used on trusted schemas only. False positive.</notes>
        <packageUrl regex="true">^pkg:maven/com\.networknt/json-schema-validator@.*$</packageUrl>
        <cve>CVE-2025-15104</cve>
    </suppress>

    <!-- False positive: CVE-2023-25822 targets the ReportPortal server-side
         service-api module (< 5.10.0 / product release < 23.2), not the Java
         client libraries consumed by our testing starter. dependency-check
         matches the generic reportportal CPE onto agent/client artifacts. -->
    <suppress>
        <notes>FP: CVE-2023-25822 applies to reportportal service-api, not agent-java-junit5/client-java test libraries.</notes>
        <packageUrl regex="true">^pkg:maven/com\.epam\.reportportal/(agent-java-junit5|client-java)@.*$</packageUrl>
        <cve>CVE-2023-25822</cve>
    </suppress>

    <!-- False positive: dependency-check maps Java OpenTelemetry artifacts to the generic
         opentelemetry:opentelemetry CPE and then applies OpenTelemetry-Go advisories.
         CVE-2026-39883 / CVE-2026-39882 / CVE-2026-29181 target opentelemetry-go on
         BSD/Solaris or OTLP-Go exporters, not Java semconv/proto artifacts consumed by
         Spring Boot tracing. -->
    <suppress>
        <notes>FP: OpenTelemetry-Go CVEs do not apply to Java io.opentelemetry.semconv or io.opentelemetry.proto artifacts.</notes>
        <packageUrl regex="true">^pkg:maven/io\.opentelemetry\.(semconv|proto)/.*@.*$</packageUrl>
        <cve>CVE-2026-39883</cve>
    </suppress>
    <suppress>
        <notes>FP: OpenTelemetry-Go CVEs do not apply to Java io.opentelemetry.semconv or io.opentelemetry.proto artifacts.</notes>
        <packageUrl regex="true">^pkg:maven/io\.opentelemetry\.(semconv|proto)/.*@.*$</packageUrl>
        <cve>CVE-2026-39882</cve>
    </suppress>
    <suppress>
        <notes>FP: CVE-2026-29181 targets OpenTelemetry-Go, not Java io.opentelemetry.semconv used by Spring Boot tracing.</notes>
        <packageUrl regex="true">^pkg:maven/io\.opentelemetry\.(semconv|proto)/.*@.*$</packageUrl>
        <cve>CVE-2026-29181</cve>
    </suppress>

    <!-- False positive: dependency-check maps the Java Testcontainers PostgreSQL helper
         artifact to the PostgreSQL server CPE and then applies server-side CVEs.
         org.testcontainers:testcontainers-postgresql is a test-scoped Java wrapper,
         not the PostgreSQL server binary itself. -->
    <suppress>
        <notes>FP: org.testcontainers:testcontainers-postgresql is a Java test helper, not a bundled PostgreSQL server distribution.</notes>
        <packageUrl regex="true">^pkg:maven/org\.testcontainers/testcontainers-postgresql@.*$</packageUrl>
        <cve>CVE-2019-10210</cve>
        <cve>CVE-2019-10211</cve>
        <cve>CVE-2015-3167</cve>
        <cve>CVE-2015-3166</cve>
        <cve>CVE-2016-0768</cve>
        <cve>CVE-2016-7048</cve>
        <cve>CVE-2018-1115</cve>
        <cve>CVE-2015-0243</cve>
        <cve>CVE-2015-0244</cve>
        <cve>CVE-2015-0241</cve>
        <cve>CVE-2015-0242</cve>
        <cve>CVE-2019-10128</cve>
        <cve>CVE-2019-10127</cve>
        <cve>CVE-2020-25694</cve>
        <cve>CVE-2016-0773</cve>
        <cve>CVE-2016-5424</cve>
        <cve>CVE-2016-5423</cve>
        <cve>CVE-2020-25695</cve>
        <cve>CVE-2017-14798</cve>
        <cve>CVE-2017-7484</cve>
        <cve>CVE-2021-23214</cve>
    </suppress>

    <!-- Accepted risk: CVE-2026-33166 (CVSS 7.5) in all io.qameta.allure artifacts.
         Allure is a test-reporting library (test scope only, never shipped to production).
         The CVE maps to the generic qameta:allure_report CPE, which targets the Allure Report
         server/HTML viewer, not the Java test artifacts (allure-model, allure-junit5, etc.)
         used to emit test results. No exploit path exists in a CI test pipeline.
         Suppression applies to all io.qameta.allure versions until a confirmed fix is available upstream. -->
    <suppress>
        <notes>Accepted: All Allure Java artifacts are test-scoped only. CVE targets Allure Report server, not Java test libraries.</notes>
        <packageUrl regex="true">^pkg:maven/io\.qameta\.allure/.*@.*$</packageUrl>
        <cve>CVE-2026-33166</cve>
    </suppress>
</suppressions>
